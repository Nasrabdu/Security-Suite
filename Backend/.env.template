# ──────────────────────────────────────────────────────────────
# Pentest Platform — environment configuration template
# Copy this file to .env and fill in the values.
#
#   cp .env.template .env
#
# Generate a strong SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ──────────────────────────────────────────────────────────────

# Flask session signing key — REQUIRED in production
# If unset the server auto-generates one per restart (sessions lost on restart)
SECRET_KEY=

# Admin account password — only read on FIRST run (when no admin exists in DB)
# If unset the server auto-generates and prints a password to the console
ADMIN_PASSWORD=

# Optional: Gemini AI API key
# GEMINI_API_KEY=

# Optional: Flask environment
FLASK_ENV=development
