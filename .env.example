# ============================================================
# Security Suite - Environment Variables EXAMPLE
# ============================================================
# 👉 انسخ هذا الملف إلى .env وضع قيمك الحقيقية:
#    cp .env.example .env
# ============================================================

# --- Flask Backend ---
SECRET_KEY=your_strong_secret_key_here
ADMIN_PASSWORD=your_admin_password_here

# --- Gemini AI API Key ---
# احصل عليه من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- CORS ---
CORS_ORIGINS=*
HTTPS_ENABLED=false

# --- PostgreSQL Database ---
POSTGRES_DB=pentest_db
POSTGRES_USER=pentest_user
POSTGRES_PASSWORD=your_strong_db_password_here
DATABASE_URL=postgresql://pentest_user:your_strong_db_password_here@db:5432/pentest_db

# --- pgAdmin ---
PGADMIN_EMAIL=admin@pentest.local
PGADMIN_PASSWORD=your_pgadmin_password_here

# --- Flask ENV ---
FLASK_ENV=development
